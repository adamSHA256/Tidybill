{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "platforms": ["linux", "windows", "macOS"],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/tidybill",
          "sidecar": true,
          "args": [
            "--gui",
            "--port",
            {
              "validator": "\\d+"
            },
            "--parent-pid",
            {
              "validator": "\\d+"
            }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/tidybill",
          "sidecar": true,
          "args": [
            "--gui",
            "--port",
            {
              "validator": "\\d+"
            },
            "--parent-pid",
            {
              "validator": "\\d+"
            }
          ]
        }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open"
  ]
}
