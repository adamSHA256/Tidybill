{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TidyBill",
  "version": "0.3.0",
  "identifier": "com.tidybill.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TidyBill",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https?://|mailto:|tel:|/|[A-Za-z]:\\\\|\\\\\\\\).+"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "dmg"],
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/tidybill"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/com.tidybill.desktop.metainfo.xml": "resources/linux/com.tidybill.desktop.metainfo.xml"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/metainfo/com.tidybill.desktop.metainfo.xml": "resources/linux/com.tidybill.desktop.metainfo.xml"
        }
      }
    }
  }
}
